@inherits LayoutComponentBase
@inject WhiteLabelContext WhiteLabelContext

<MudThemeProvider Theme="@Theme" IsDarkMode="false" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout Class="shell-layout" Style="@ShellStyle">
    <AuthorizeView>
        <Authorized>
            <MudAppBar Elevation="0" Dense="true" Class="top-bar px-4" Style="@($"background:{WhiteLabelContext.CurrentPanel.AppBarColor};color:{WhiteLabelContext.CurrentPanel.NavTextColor};")">
                <MudLink Href='@WhiteLabelContext.GetPath()' Underline="Underline.None" Class="brand-link">
                    <img src="@WhiteLabelContext.CurrentPanel.LogoPath" alt="Logo" class="brand-logo" />
                    <span class="brand-text">@WhiteLabelContext.CurrentPanel.DisplayName</span>
                </MudLink>

                <MudSpacer />

                <div class="top-nav">
                    <MudButton Href='@WhiteLabelContext.GetPath()' Variant="Variant.Text" Color="Color.Inherit" Class="nav-link">Home</MudButton>
                    <MudButton Href='@WhiteLabelContext.GetPath("cases")' Variant="Variant.Text" Color="Color.Inherit" Class="nav-link">Cases</MudButton>
                    <MudButton Href='@WhiteLabelContext.GetPath("new-enquiry")' Variant="Variant.Filled" Color="Color.Default" Class="new-enquiry-button button-primary">New Enquiry</MudButton>
                    <MudMenu Icon="@Icons.Material.Filled.AccountCircle" Color="Color.Inherit" Size="Size.Medium" AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight">
                        <MudMenuItem Href='@WhiteLabelContext.GetPath("user-preferences")'>User preferences</MudMenuItem>
                        <MudMenuItem Href='@($"{WhiteLabelContext.RootPath("authentication/logout")}?returnUrl={Uri.EscapeDataString(WhiteLabelContext.GetPath())}")'>Sign out</MudMenuItem>
                    </MudMenu>
                </div>
            </MudAppBar>
        </Authorized>
    </AuthorizeView>

    <MudMainContent Class="page-shell">
        @Body
    </MudMainContent>

    <MudPaper Square="true" Elevation="0" Class="app-footer" Style="@($"background:{WhiteLabelContext.CurrentPanel.FooterColor};color:{WhiteLabelContext.CurrentPanel.NavTextColor};")">
        <MudContainer MaxWidth="MaxWidth.False" Class="footer-inner">
            <MudText Typo="Typo.body2">@WhiteLabelContext.CurrentPanel.DisplayName portal</MudText>
            <MudText Typo="Typo.caption">Secure case and enquiry workspace</MudText>
        </MudContainer>
    </MudPaper>
</MudLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">x</span>
</div>

<style>
    :global(.mud-input-control .mud-input-slot),
    :global(.mud-input-control .mud-select-input),
    :global(.mud-input-control .mud-input-root),
    :global(.mud-picker-input-control) {
        border-radius: 9999px !important;
    }

    :global(.mud-input-control textarea.mud-input-slot) {
        border-radius: 28px !important;
    }

    .shell-layout {
        min-height: 100vh;
    }

    .top-bar {
        min-height: 76px;
    }

    .brand-link {
        display: inline-flex;
        align-items: center;
        gap: 0.85rem;
        color: var(--panel-nav-text-color);
    }

    .brand-logo {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: block;
    }

    .brand-text {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.03em;
    }

    .top-nav {
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

    .nav-link {
        color: #ffffff;
        font-weight: 600;
        text-transform: none;
    }

    .new-enquiry-button {
        margin-left: 0.5rem;
        text-transform: none;
        font-weight: 700;
        box-shadow: none;
    }

    .page-shell {
        min-height: calc(100vh - 140px);
    }

    .app-footer {
    }

    .footer-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 1.5rem;
    }

    @@media (max-width: 960px) {
        .top-bar {
            flex-wrap: wrap;
            gap: 0.75rem;
            padding-top: 0.85rem;
            padding-bottom: 0.85rem;
        }

        .top-nav {
            width: 100%;
            justify-content: space-between;
            flex-wrap: wrap;
        }

        .new-enquiry-button {
            margin-left: 0;
        }

        .footer-inner {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    private string ShellStyle =>
        $"--panel-appbar-color:{WhiteLabelContext.CurrentPanel.AppBarColor};" +
        $"--panel-footer-color:{WhiteLabelContext.CurrentPanel.FooterColor};" +
        $"--panel-background-color:{WhiteLabelContext.CurrentPanel.BackgroundColor};" +
        $"--panel-surface-color:{WhiteLabelContext.CurrentPanel.SurfaceColor};" +
        $"--panel-surface-accent-color:{WhiteLabelContext.CurrentPanel.SurfaceAccentColor};" +
        $"--panel-border-color:{WhiteLabelContext.CurrentPanel.BorderColor};" +
        $"--panel-text-primary-color:{WhiteLabelContext.CurrentPanel.TextPrimaryColor};" +
        $"--panel-text-secondary-color:{WhiteLabelContext.CurrentPanel.TextSecondaryColor};" +
        $"--panel-nav-text-color:{WhiteLabelContext.CurrentPanel.NavTextColor};" +
        $"--panel-primary-button-color:{WhiteLabelContext.CurrentPanel.PrimaryButtonColor};" +
        $"--panel-primary-button-text-color:{WhiteLabelContext.CurrentPanel.PrimaryButtonTextColor};" +
        $"--panel-secondary-button-color:{WhiteLabelContext.CurrentPanel.SecondaryButtonColor};" +
        $"--panel-secondary-button-text-color:{WhiteLabelContext.CurrentPanel.SecondaryButtonTextColor};" +
        $"--panel-tertiary-button-color:{WhiteLabelContext.CurrentPanel.TertiaryButtonColor};" +
        $"--panel-tertiary-button-text-color:{WhiteLabelContext.CurrentPanel.TertiaryButtonTextColor};" +
        $"--panel-accent-text-color:{WhiteLabelContext.CurrentPanel.AccentTextColor};" +
        $"--metric-card-primary-start:{WhiteLabelContext.CurrentPanel.MetricCardPrimaryStart};" +
        $"--metric-card-primary-end:{WhiteLabelContext.CurrentPanel.MetricCardPrimaryEnd};" +
        $"--metric-card-secondary-start:{WhiteLabelContext.CurrentPanel.MetricCardSecondaryStart};" +
        $"--metric-card-secondary-end:{WhiteLabelContext.CurrentPanel.MetricCardSecondaryEnd};" +
        $"--metric-card-tertiary-start:{WhiteLabelContext.CurrentPanel.MetricCardTertiaryStart};" +
        $"--metric-card-tertiary-end:{WhiteLabelContext.CurrentPanel.MetricCardTertiaryEnd};" +
        $"--metric-card-quaternary-start:{WhiteLabelContext.CurrentPanel.MetricCardQuaternaryStart};" +
        $"--metric-card-quaternary-end:{WhiteLabelContext.CurrentPanel.MetricCardQuaternaryEnd};" +
        $"--auth-glow-primary:{ToRgba(WhiteLabelContext.CurrentPanel.PrimaryColor, 0.16)};" +
        $"--auth-glow-secondary:{ToRgba(WhiteLabelContext.CurrentPanel.SecondaryColor, 0.16)};" +
        $"min-height:100vh;background:radial-gradient(circle at top left, {ToRgba(WhiteLabelContext.CurrentPanel.PrimaryColor, 0.12)}, transparent 28%),linear-gradient(180deg, {WhiteLabelContext.CurrentPanel.BackgroundColor} 0%, {WhiteLabelContext.CurrentPanel.SurfaceAccentColor} 45%, {WhiteLabelContext.CurrentPanel.BackgroundColor} 100%);";
    private MudTheme Theme =>
        new()
        {
            PaletteLight = new PaletteLight
            {
                Primary = WhiteLabelContext.CurrentPanel.PrimaryColor,
                Secondary = WhiteLabelContext.CurrentPanel.SecondaryColor,
                Tertiary = WhiteLabelContext.CurrentPanel.TertiaryColor,
                Background = WhiteLabelContext.CurrentPanel.BackgroundColor,
                Surface = WhiteLabelContext.CurrentPanel.SurfaceColor,
                AppbarBackground = WhiteLabelContext.CurrentPanel.AppBarColor,
                AppbarText = WhiteLabelContext.CurrentPanel.NavTextColor,
                DrawerBackground = WhiteLabelContext.CurrentPanel.AppBarColor,
                TextPrimary = WhiteLabelContext.CurrentPanel.TextPrimaryColor,
                TextSecondary = WhiteLabelContext.CurrentPanel.TextSecondaryColor,
                Success = WhiteLabelContext.CurrentPanel.SecondaryColor,
                Warning = WhiteLabelContext.CurrentPanel.TertiaryColor,
                Error = WhiteLabelContext.CurrentPanel.PrimaryColor,
                Info = WhiteLabelContext.CurrentPanel.PrimaryButtonColor,
                LinesDefault = WhiteLabelContext.CurrentPanel.BorderColor,
                TableLines = WhiteLabelContext.CurrentPanel.BorderColor
            },
            Typography = new Typography
            {
                Default = new DefaultTypography
                {
                    FontFamily = ["Segoe UI", "Arial", "sans-serif"]
                }
            }
        };

    private static string ToRgba(string hexColor, double alpha)
    {
        var trimmed = hexColor.TrimStart('#');
        if (trimmed.Length != 6)
        {
            return $"rgba(63, 130, 220, {alpha.ToString(System.Globalization.CultureInfo.InvariantCulture)})";
        }

        var red = Convert.ToInt32(trimmed[..2], 16);
        var green = Convert.ToInt32(trimmed[2..4], 16);
        var blue = Convert.ToInt32(trimmed[4..6], 16);
        return $"rgba({red}, {green}, {blue}, {alpha.ToString(System.Globalization.CultureInfo.InvariantCulture)})";
    }
}
