@page "/user-preferences"
@page "/{PanelPath}/user-preferences"
@attribute [Authorize]

<PageTitle>User Preferences</PageTitle>

<MudContainer MaxWidth="MaxWidth.Medium" Class="py-10">
    <MudPaper Class="pa-8" Elevation="0" Style="border:1px solid #d7e2f0;">
        <MudBreadcrumbs Items="@_breadcrumbs" Class="mb-4" />
        <MudText Typo="Typo.h3" GutterBottom="true">User preferences</MudText>
        <MudText Typo="Typo.body1" Class="mb-6">
            Manage your personal details and default communication preferences.
        </MudText>

        <MudStack Spacing="3">
            <MudTextField T="string" Label="First name" Variant="Variant.Outlined" @bind-Value="_model.FirstName" />
            <MudTextField T="string" Label="Surname" Variant="Variant.Outlined" @bind-Value="_model.Surname" />

            <MudPaper Class="pa-4" Elevation="0" Style="border:1px solid #d7e2f0;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <div>
                        <MudText Typo="Typo.subtitle1">Include demands and needs statement with issued policies</MudText>
                        <MudText Typo="Typo.body2">Automatically include the statement when policies are issued.</MudText>
                    </div>
                    <MudSwitch T="bool" Color="Color.Secondary" @bind-Value="_model.IncludeDemandsAndNeedsStatement" />
                </MudStack>
            </MudPaper>

            <MudPaper Class="pa-4" Elevation="0" Style="border:1px solid #d7e2f0;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                    <div>
                        <MudText Typo="Typo.subtitle1">Receive email updates</MudText>
                        <MudText Typo="Typo.body2">Get notification emails for policy activity and workflow updates.</MudText>
                    </div>
                    <MudSwitch T="bool" Color="Color.Secondary" @bind-Value="_model.ReceiveEmailUpdates" />
                </MudStack>
            </MudPaper>

            <MudButton Variant="Variant.Filled" Color="Color.Default" Class="px-6 button-primary" Style="align-self:flex-start;">
                Save preferences
            </MudButton>
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    [Parameter]
    public string? PanelPath { get; set; }

    private readonly PreferencesModel _model = new()
    {
        FirstName = "Laura",
        Surname = "Saunders",
        IncludeDemandsAndNeedsStatement = true,
        ReceiveEmailUpdates = true
    };

    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("User preferences", href: null, disabled: true)
    ];

    private class PreferencesModel
    {
        public string FirstName { get; set; } = string.Empty;

        public string Surname { get; set; } = string.Empty;

        public bool IncludeDemandsAndNeedsStatement { get; set; }

        public bool ReceiveEmailUpdates { get; set; }
    }
}
